# This file controls what gets uploaded to Cloud Build.
# IMPORTANT: *.db is intentionally NOT listed here so that database
# files in the repo root are included in cloud builds.
# Without this file, gcloud falls back to .gitignore which excludes *.db.

.git
.gitignore
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
.env
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
tests/
